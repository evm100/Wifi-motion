menu "WiFi Manager Configuration"

    config CSI_WIFI_SSID
        string "WiFi hotspot SSID"
        default "iPhone"
        help
            SSID of the WiFi hotspot (e.g. iPhone personal hotspot).

    config CSI_WIFI_PASSWORD
        string "WiFi hotspot password"
        default "changeme123"
        help
            WPA2 password for the WiFi hotspot.

    config CSI_WIFI_CHANNEL
        int "WiFi channel (0 = auto-scan)"
        range 0 13
        default 0
        help
            WiFi channel. Set to 0 for auto-scan (recommended when using
            a phone hotspot since the channel is chosen by the phone).

    config CSI_WIFI_MAX_RETRY
        int "Maximum WiFi reconnect attempts"
        range 0 255
        default 10
        help
            Number of reconnect attempts before giving up. 0 = infinite.

endmenu
