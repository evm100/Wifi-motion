menu "Time Sync Configuration"

    config CSI_SNTP_SERVER
        string "SNTP server address"
        default "pool.ntp.org"
        help
            SNTP server hostname or IP. Uses a public NTP server since
            all nodes have internet access via the phone hotspot.

    config CSI_SNTP_SYNC_TIMEOUT
        int "SNTP sync timeout retries"
        range 1 30
        default 7
        help
            Number of 2-second retries waiting for initial SNTP sync.

endmenu
