menu "CSI Node Configuration"

    config CSI_NODE_ID
        int "Node ID (unique per RX device)"
        range 1 255
        default 1
        help
            Unique identifier for this CSI receiver node.
            TX node = 0, RX nodes = 1, 2, 3.

    config CSI_TARGET_IP
        string "Aggregator IP address"
        default "172.20.10.2"
        help
            IP address of the Raspberry Pi aggregator on the hotspot network.
            iPhone hotspots typically assign IPs in the 172.20.10.x range.
            Check the Pi's IP after it connects and set this accordingly.

    config CSI_TARGET_PORT
        int "Aggregator UDP port"
        range 1024 65535
        default 5005
        help
            UDP port the aggregator listens on.

    config CSI_TX_MAC
        string "TX node MAC address (AA:BB:CC:DD:EE:FF)"
        default "FF:FF:FF:FF:FF:FF"
        help
            MAC address of the TX node to filter CSI frames.
            Set to FF:FF:FF:FF:FF:FF to accept all frames.

    config CSI_WIFI_SSID
        string "WiFi hotspot SSID"
        default "iPhone"
        help
            SSID of the WiFi hotspot (e.g. iPhone personal hotspot).

    config CSI_WIFI_PASSWORD
        string "WiFi hotspot password"
        default "changeme123"
        help
            WPA2 password for the WiFi hotspot.

    config CSI_WIFI_CHANNEL
        int "WiFi channel (0 = auto-scan)"
        range 0 13
        default 0
        help
            WiFi channel. Set to 0 for auto-scan (recommended when using
            a phone hotspot since the channel is chosen by the phone).

endmenu
